# ---- Supabase ----
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=      # server-only; never expose to the browser

# ---- Auth (simple hash-based login) ----
ADMIN_USERNAME=khalid
ADMIN_PASSWORD_HASH=            # run: node scripts/hash.js <your-password>
AUTH_SALT=change-me-random
AUTH_SECRET=change-me-random   # signs session tokens

# ---- Cron (cron-job.org calls /api/poll-disclosures?secret=...) ----
CRON_SECRET=change-me-random

# ---- Data feeds (leave blank for now; app runs on mock adapters) ----
QUIVER_API_KEY=
SCREENING_API_KEY=

# ---- AI (optional, later) ----
ANTHROPIC_API_KEY=
